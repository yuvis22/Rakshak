# Mesh API — get your key at https://app.meshapi.ai (API Keys section)
# Every AI call in Rakshak routes through Mesh. This is the only provider key needed.
MESH_API_KEY=rsk_your_key_here

# Base URL for the Mesh gateway (OpenAI-compatible)
MESH_BASE_URL=https://api.meshapi.ai/v1

# Force the offline mock engine even when a valid key is set (useful for demos)
# MESH_FORCE_MOCK=1
